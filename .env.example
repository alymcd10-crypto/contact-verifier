# Database
# SQLite (dev): sqlite:///./crm.db
# Postgres (prod): postgresql://user:pass@host:5432/crm
DB_URL=sqlite:///./crm.db

# CORS — comma-separated list, or * for development
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# ─── SMS via Twilio (optional) ─────────────────────────
# Leave unset to run in "demo mode" (messages logged but not sent)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+18475551234

# ─── Email via M365 Graph (coming soon) ────────────────
# M365_CLIENT_ID=
# M365_TENANT_ID=
# M365_CLIENT_SECRET=
